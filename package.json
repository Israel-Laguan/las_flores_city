{
  "name": "las-flores-2077",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "admin",
    "shared"
  ],
  "scripts": {
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "dev:admin": "npm run dev --workspace=admin",
    "migrate": "npm run migrate --workspace=server",
    "validate:content": "npm run validate --workspace=server",
