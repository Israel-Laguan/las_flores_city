# Las Flores 2077 - Environment Variables
# Copy this file to .env and fill in values for local development
# WARNING: Do NOT commit .env with real secrets to version control!

# =============================================================================
# DEVELOPMENT DEFAULTS (override these in production!)
# =============================================================================

DATABASE_URL=postgresql://las_flores:las_flores_dev_password@localhost:5432/las_flores
ANALYTICS_DATABASE_URL=postgresql://las_flores_analytics:las_flores_analytics_dev_password@localhost:5433/las_flores_analytics
REDIS_URL=redis://localhost:6379
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
JWT_SECRET=your-jwt-secret-change-in-production
CDN_SIGNING_SECRET=your-cdn-signing-secret-change-in-production
CDN_BASE_URL=https://cdn.lasflores2077.com
CDN_KEY_PAIR_ID=APKAEXAMPLE000000000000
CDN_PRIVATE_KEY_PATH=/etc/secrets/cdn_private_key.pem
SIGNED_URL_TTL_SECONDS=900
PORT=3000
NODE_ENV=development
VITE_API_URL=http://localhost:3000
VITE_ABOUT_US_URL=https://example.com/about-us
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3-pro-preview
GROQ_API_KEY=your-groq-api-key
NVIDIA_API_KEY=your-nvidia-api-key
CLIENT_BASE_URL=http://localhost:5173
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id
PATREON_CLIENT_ID=your-patreon-client-id
PATREON_CLIENT_SECRET=your-patreon-client-secret
PATREON_REDIRECT_URI=http://localhost:3000/patreon/callback
PATREON_NSFW_TIER_IDS=
GOLD_CREDITS_PER_USD=100

# Story Builder LLM Configuration
LLM_PROVIDER=mock              # mock | litellm | gemini | groq (all real providers use LiteLLM proxy)
LITELLM_BASE_URL=http://litellm:4000  # URL for LiteLLM proxy (internal Docker network)
LITELLM_API_KEY=local-key     # API key for LiteLLM proxy auth (matches master_key in config)
LLM_MODEL=poolside/laguna-m.1 # Model alias from litellm-config.yaml (poolside/laguna-m.1, poolside/laguna-xs.2, openrouter/owl-alpha)

# Local dev admin seed (consumed by `npm run seed:dev`)
# Set these to auto-create a dev admin user during local setup.
# Leave ADMIN_PASSWORD empty to skip seeding (no admin created).
# Never commit a real password here — keep it in your local .env.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
ADMIN_USER_ID=00000000-0000-0000-0000-000000000001
