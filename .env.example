# Las Flores 2077 - Environment Variables
# Copy this file to .env and fill in values for local development
# WARNING: Do NOT commit .env with real secrets to version control!

# =============================================================================
# DEVELOPMENT DEFAULTS (override these in production!)
# =============================================================================

# Database Configuration - Use Docker service names in compose, localhost for local dev
DATABASE_URL=postgresql://las_flores:las_flores_dev_password@localhost:5432/las_flores
ANALYTICS_DATABASE_URL=postgresql://las_flores_analytics:las_flores_analytics_dev_password@localhost:5433/las_flores_analytics
# Production: Set these to use Docker secrets
# POSTGRES_PASSWORD=/run/secrets/postgres_password
# POSTGRES_ANALYTICS_PASSWORD=/run/secrets/postgres_analytics_password

# Redis Configuration
REDIS_URL=redis://localhost:6379

# MinIO/S3 Configuration
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Production: Use Docker secrets
# MINIO_ROOT_USER=/run/secrets/minio_root_user
# MINIO_ROOT_PASSWORD=/run/secrets/minio_root_password

# JWT Configuration - CRITICAL: Change in production!
JWT_SECRET=your-jwt-secret-change-in-production
# Production: Use Docker secrets
# JWT_SECRET_FILE=/run/secrets/jwt_secret

CDN_SIGNING_SECRET=your-cdn-signing-secret-change-in-production

# Secure Vault Delivery (Task 4.4)
# CDN_BASE_URL: origin used when constructing a signed URL. Supports
# AWS CloudFront or Pushr.io (adult CDN) by pointing at the right edge.
# CDN_KEY_PAIR_ID: the CloudFront public key id (APKA...) associated with
# the private key file. Pushr exposes an equivalent identifier.
# CDN_PRIVATE_KEY_PATH: absolute path to the PEM private key used to
# sign the URL. Mount this in production via Docker secrets, NOT env.
# SIGNED_URL_TTL_SECONDS: how long a signed URL is valid (default 900 = 15 min).
CDN_BASE_URL=https://cdn.lasflores2077.com
CDN_KEY_PAIR_ID=APKAEXAMPLE000000000000
CDN_PRIVATE_KEY_PATH=/etc/secrets/cdn_private_key.pem
SIGNED_URL_TTL_SECONDS=900
# Production: Mount private key via Docker secret to this path
# CDN_PRIVATE_KEY_PATH=/run/secrets/cdn_private_key.pem

# =============================================================================
# SERVER & CLIENT CONFIGURATION
# =============================================================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Client Configuration
VITE_API_URL=http://localhost:3000

# About Us link shown on the main menu
VITE_ABOUT_US_URL=https://example.com/about-us

# AI Configuration - Get keys from respective providers
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3-pro-preview
GROQ_API_KEY=your-groq-api-key
NVIDIA_API_KEY=your-nvidia-api-key

# Client Configuration (used for OAuth return_url / cancel_url)
CLIENT_BASE_URL=http://localhost:5173
# Production: Change to your production URL
# CLIENT_BASE_URL=https://play.lasflores2077.com

# =============================================================================
# PAYMENTS & ECONOMY
# =============================================================================

# PayPal Configuration
# PAYPAL_MODE: 'sandbox' (default) or 'live'
#   sandbox → https://api-m.sandbox.paypal.com
#   live    → https://api-m.paypal.com
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret
# PAYPAL_WEBHOOK_ID is the stable webhook id from the PayPal dashboard.
# Required for verify-webhook-signature. In dev/sandbox without it, the
# webhook skips signature verification and logs a warning.
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id
# Production: Use Docker secrets for client secret
# PAYPAL_SECRET_FILE=/run/secrets/paypal_secret

# Patreon Integration - Get from https://www.patreon.com/portal/registration
PATREON_CLIENT_ID=your-patreon-client-id
PATREON_CLIENT_SECRET=your-patreon-client-secret
PATREON_REDIRECT_URI=http://localhost:3000/patreon/callback
PATREON_NSFW_TIER_IDS=
# Production: Use Docker secrets
# PATREON_CLIENT_SECRET_FILE=/run/secrets/patreon_client_secret

# Gold Credits economy (live-ops knob for "Double Gold Weekend" etc.)
# 1 USD = GOLD_CREDITS_PER_USD gold credits (default 100)
GOLD_CREDITS_PER_USD=100

# =============================================================================
# ADMIN PANEL
# =============================================================================
# The admin Next.js app (port 3001) reads the same DATABASE_URL as
# the server. In Docker, docker-compose injects this automatically
# using the postgres-oltp service name. For local dev outside Docker,
# set DATABASE_URL here and it applies to both server and admin.

# =============================================================================
# PRODUCTION DEPLOYMENT NOTES
# =============================================================================
# For production deployments:
# 1. Use docker-compose.prod.yml override
# 2. Mount secrets via Docker secrets or external secrets manager
# 3. Remove public port mappings from database services
# 4. Set NODE_ENV=production
# 5. Use a reverse proxy (nginx, traefik) in front of the services
#
# Example production deployment:
#   docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d
